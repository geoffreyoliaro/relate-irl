# Copy to .env for local development or set as GitHub/GCP secrets
# Never commit this file — it's in .gitignore

# FalkorDB Cloud Configuration
# Cloud instance: deploy_instance_1
# For local development, use localhost:6379
# For GCP Cloud Run, use the cloud instance endpoint
FALKORDB_HOST=deploy_instance_1.falkordb.io
FALKORDB_PORT=6379
FALKORDB_USER=oliaro
FALKORDB_PASSWORD=Pasnipop

# Generate a strong secret: openssl rand -hex 32
# IMPORTANT: Generate a unique JWT_SECRET and add to GitHub/GCP secrets
JWT_SECRET=local-dev-secret-change-in-prod

# Your Xano instance base URL (from Xano dashboard → API Base URL)
# IMPORTANT: Replace with your actual Xano instance URL
XANO_API_BASE=https://your-instance.xano.io/api:xxxx

GIN_MODE=debug
